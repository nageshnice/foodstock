# Application
APP_NAME=Food Stock API
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# MySQL via XAMPP (async SQLAlchemy driver)
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/food_stock
DB_ECHO=false
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=food_stock

# Security - generate a long random value for each environment
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# JSON array of trusted frontend origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Commerce defaults (Indian rupees)
DEFAULT_TAX_RATE=5.00
DELIVERY_FEE=5.00
FREE_DELIVERY_THRESHOLD=499.00
MINIMUM_ORDER_AMOUNT=199.00

# Public URL prefix (empty for local dev; /foodstock on production)
ROOT_PATH=

# Required only by the admin bootstrap command; never commit real values
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace_with_a_strong_admin_password
