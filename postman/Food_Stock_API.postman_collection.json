                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "type": "text"
                            }
                        ]
                    }
                },
                {
                    "name": "Brands by Region",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/catalog/brands?region_id={{region_id}}",
