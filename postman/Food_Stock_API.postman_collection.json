{
    "info": {
        "_postman_id": "4ea78df5-31e2-44a7-9f20-foodstockapi",
        "name": "Food Stock API - Phase 1",
        "description": "Customer mobile flow and React admin APIs. Run Signup or Login first; their test scripts save the bearer token automatically.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://127.0.0.1:8000/api/v1"
        },
        {
            "key": "token",
            "value": ""
        },
        {
            "key": "product_id",
            "value": ""
        },
        {
            "key": "variant_id",
            "value": ""
        },
        {
            "key": "cart_item_id",
            "value": ""
        },
        {
            "key": "address_id",
            "value": ""
        },
        {
            "key": "order_id",
            "value": ""
        },
        {
            "key": "region_id",
            "value": ""
        },
        {
            "key": "category_id",
            "value": ""
        },
        {
            "key": "brand_id",
            "value": ""
        },
        {
            "key": "vendor_id",
            "value": ""
        },
        {
            "key": "customer_id",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Signup",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) pm.collectionVariables.set('token', pm.response.json().data.access_token);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"StrongPassword123!\",\n  \"confirm_password\": \"StrongPassword123!\"\n}"
                        },
                        "url": "{{base_url}}/auth/signup"
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) pm.collectionVariables.set('token', pm.response.json().data.access_token);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"StrongPassword123!\"\n}"
                        },
                        "url": "{{base_url}}/auth/login"
                    }
                }
            ]
        },
        {
            "name": "Catalog",
            "item": [
                {
                    "name": "Regions",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/catalog/regions",
                        "header": [
