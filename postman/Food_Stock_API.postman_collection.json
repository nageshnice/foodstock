        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Signup",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/signup",
                        "auth": {
                            "type": "noauth"
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"StrongPassword123!\",\n  \"confirm_password\": \"StrongPassword123!\"\n}"
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ]
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "  const data = pm.response.json().data;",
                                    "  pm.collectionVariables.set('token', data.access_token);",
                                    "  if (data.api_key) pm.collectionVariables.set('api_key', data.api_key);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "auth": {
                            "type": "noauth"
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"StrongPassword123!\"\n}"
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ]
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  const data = pm.response.json().data;",
                                    "  pm.collectionVariables.set('token', data.access_token);",
                                    "  if (data.api_key) pm.collectionVariables.set('api_key', data.api_key);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/logout",
