                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "type": "text"
                            }
                        ]
                    }
                },
                {
                    "name": "Categories",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/catalog/categories",
                        "header": [
