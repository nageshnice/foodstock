                },
                {
                    "name": "Products with Filters",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/catalog/products?region_id={{region_id}}&brand_id={{brand_id}}&search=&page=1&page_size=20",
                        "header": [
