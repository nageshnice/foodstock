# Production environment — copy to .env on the server (never commit .env)

APP_NAME=Food Stock API
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO

# MySQL (async SQLAlchemy driver)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=foodstock
DB_USERNAME=foodstock_user
DB_PASSWORD=replace_with_strong_db_password
DATABASE_URL=mysql+aiomysql://foodstock_user:replace_with_strong_db_password@127.0.0.1:3306/foodstock
DB_ECHO=false

# Security — generate a unique random string (min 32 chars)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Trusted frontends (JSON array)
CORS_ORIGINS=["https://rankplex.cloud","https://www.rankplex.cloud"]

# Reverse-proxy subpath (Swagger/OpenAPI URLs)
ROOT_PATH=/foodstock

DEFAULT_TAX_RATE=5.00
DELIVERY_FEE=5.00
FREE_DELIVERY_THRESHOLD=499.00
MINIMUM_ORDER_AMOUNT=199.00

# One-time admin bootstrap (remove password after first run)
BOOTSTRAP_ADMIN_EMAIL=admin@rankplex.cloud
BOOTSTRAP_ADMIN_PASSWORD=replace_with_strong_admin_password
